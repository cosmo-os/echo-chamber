{
  "name": "echo-chamber",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mobile": "node scripts/dev-mobile.mjs",
    "build": "tsc && vite build",
    "build:pages": "GITHUB_PAGES=true npm run build",
    "preview": "vite preview",
